// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String      @id @default(uuid())
  auth0Id           String      @unique @db.VarChar(150)
  email             String      @unique @db.VarChar(150)
  emailVerified     Boolean?    @db.Boolean
  picture           String?     @db.VarChar(250)
  name              String?     @db.VarChar(150)
  googleCalendarId  String?

  createAt          DateTime    @db.Timestamptz(3)    @default(now())
  updateAt          DateTime    @db.Timestamptz(3)    @updatedAt

  bookings          Booking[]
}

model Booking {
  id          String      @id @default(uuid())
  date        DateTime
  title       String      @db.VarChar(250)

  startsAt     DateTime   @db.Timestamptz(3)
  endsAt       DateTime   @db.Timestamptz(3)

  createAt    DateTime    @db.Timestamptz(3)    @default(now())
  updateAt    DateTime    @db.Timestamptz(3)    @updatedAt
  googleEventId String?

  @@index([userAuth0Id, startsAt])

  userAuth0Id  String
  user        User        @relation(fields: [userAuth0Id], references: [auth0Id])
}
